# ── Core ────────────────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=True
# Comma-separated, no http://
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_BASE_URL=http://localhost:5173

# Production: uncomment and fill these
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Database ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/splitwise
MONGODB_DB_NAME=splitwise

# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# SQLite path (Django internal tables only — not app data)
# SQLITE_PATH=/data/db.sqlite3

# ── Redis (required for WebSocket channel layer in production) ───
# REDIS_URL=redis://127.0.0.1:6379/0
# Production (Upstash / Railway Redis):
# REDIS_URL=rediss://default:<password>@host:6379

# ── Auth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
BYPASS_SIGNUP_OTP_CODE=000000

# ── Email (OTP + settlement notifications) ───────────────────────
# Leave EMAIL_HOST_USER blank to fall back to console backend locally
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Balance Studio <your-email@gmail.com>
SIGNUP_OTP_EXPIRATION_MINUTES=10
